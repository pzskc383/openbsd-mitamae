    listen on $loopback port $httpd_tls_port

    log {
        style forwarded
        access "access.mail.log"
        error "error.mail.log"
    }

    location /mail/config-v1.1.xml {
        root "/htdocs/mail/<%= @domain %>/mozilla_autoconf"
