# mta-sts for <%= @domain %>
server "_sts_<%= @domain_nodots %>" {
    alias "mta-sts."

    listen on $loopback port $httpd_tls_port

    log {
        style forwarded
        access "access.mail.log"
        error "error.mail.log"
    }

    location .well-known/mta-sts.txt {
        root "/htdocs/mail/<%= @domain %>/mta-sts"
    }

    location * { return }
}

# thunderbird autoconfig for <%= @domain %>
server "_tb_autoconf_<%= @domain_nodots %>" {
