# static domain
server "_pzskc383_static" {
    alias "i.pzskc383.net"
    alias "pub.pzskc383.net"
    alias "i.pzskc383.dp.ua"
    alias "pub.pzskc383.dp.ua"

    log {
        style forwarded
        access "access.main-static.log"
        error "error.main-static.log"
    }

    listen on $loopback port $httpd_plain_port
    listen on $loopback port $httpd_tls_port

    location * {
        root "/htdocs/pub"
        directory auto index
    }
}

# main domain
server "_pzskc383_main" {
    alias "*.pzskc383.net"
    alias "pzskc383.net"
    alias "*.pzskc383.dp.ua"
    alias "pzskc383.dp.ua"

    listen on $loopback port $httpd_tls_port

    log {
        style forwarded
        access "access.main.log"
        error "error.main.log"
    }

    # cgit static
    location match "^/code/cgit/%w+%.%w+$" {
        log {
            style forwarded
            access "access.cgit.log"
            error "error.cgit.log"
        }
        root "/cgit"
        request strip 2
        no fastcgi
    }

    # git dumb static
    location match "^/code/[^/]+/objects/%x%x/%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x$" {
        request strip 1
        root "/repos"
        log {
            style forwarded
            access "access.git-dumb.log"
            error "error.git-dumb.log"
        }
    }

    location match "^/code/[^/]+/objects/pack/pack-%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x.pack$" {
        request strip 1
        root "/repos"
        log {
            style forwarded
            access "access.git-dumb.log"
            error "error.git-dumb.log"
        }
    }

    location match "^/code/[^/]+/objects/pack/pack-%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x%x.idx$" {
        request strip 1
        root "/repos"
        log {
            style forwarded
            access "access.git-dumb.log"
            error "error.git-dumb.log"
        }
    }


    location "/code/*/git-upload-pack" {
        request strip 1
        log {
            style forwarded
            access "access.git-backend.log"
            error "error.git-backend.log"
        }
        root "/cgi-bin/git-http-backend"
        fastcgi {
            socket "/run/slowcgi.sock"
            param DOCUMENT_ROOT "/"
            param GIT_PROJECT_ROOT "/repos"
            param GIT_CONFIG_COUNT "1"
            param GIT_CONFIG "/repos/.gitconfig"
            param GIT_CONFIG_KEY_1 "safe.directory"
            param GIT_CONFIG_VALUE_1 "/repos"
            param HOME "/repos"
        }
    }

    location "/code/*/info/refs" {
        request strip 1
        log {
            style forwarded
            access "access.git-backend.log"
            error "error.git-backend.log"
        }
        root "/cgi-bin/git-http-backend"
        fastcgi {
            socket "/run/slowcgi.sock"
            param DOCUMENT_ROOT "/"
            param GIT_PROJECT_ROOT "/repos"
            param GIT_CONFIG "/repos/.gitconfig"
            # param GIT_CONFIG_KEY_1 "safe.directory"
            # param GIT_CONFIG_VALUE_1 "/repos"
            param HOME "/repos"
        }
    }

    # cgit
    location "/code*" {
        root "/cgi-bin/cgit.cgi"
        log {
            style forwarded
            access "access.cgit.log"
            error "error.cgit.log"
        }
        request strip 1
        fastcgi {
            socket "/run/slowcgi.sock"
        }
    }

    # gotwebd
    location "/got" {
        block return 301 "/got/"
    }
    location "/got/" {
        fastcgi { socket "/run/gotweb.sock" }
    }

    location "/got/*" {
        root "/htdocs/gotwebd"
        request strip 1
    }

    location * {
        root "/htdocs/pzskc383"
    }
}

# http -> https redirects
server "_main_plain" {
    alias "*.pzskc383.net"
    alias "pzskc383.net"
    alias "*.pzskc383.dp.ua"
    alias "pzskc383.dp.ua"

    listen on $loopback port $httpd_plain_port

    log {
        style forwarded
        access "access.main-plain.log"
        error "error.main-plain.log"
    }

    location "/.well-known/acme-challenge/*" {
        root "/htdocs/pzskc383"
    }

    location * {
        block return 302 "https://$HTTP_HOST$REQUEST_URI"
    }
}
