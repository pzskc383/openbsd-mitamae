# main domain
server "_box_main" {
    alias "b0x.pw"

    listen on $loopback port $httpd_plain_port
    listen on $loopback port $httpd_tls_port

    errdocs "/htdocs/box_main/err"

    log {
        style forwarded
        access "access.box_main.log"
        error "error.box_main.log"
    }

    location * {
        root "/htdocs/box_main"
    }
}
