include "/etc/httpd.conf.d/macro.conf"
loopback = "lo0"

errdocs "errdocs/"

include "/etc/httpd.conf.d/default.conf"
include "/etc/httpd.conf.d/fqdn.conf"

<%- node[:httpd_config_files].each do |filename| -%>
include "/etc/httpd.conf.d/<%= filename %>"
<%- end -%>

types {
    include "/usr/share/misc/mime.types"
}
