tls_opts = "edh params auto, no tlsv1.0, session tickets, ciphers TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256"

http protocol www_tls {
    tcp { nodelay }

    tls { keypair <%= node[:fqdn] %>, $tls_opts }
<%- node[:relayd_domains].each do |domain| -%>
    tls { keypair <%= domain %>, $tls_opts }
<%- end -%>

    include "/etc/relayd.conf.d/http_headers.conf"
    
    return error
    pass
}

relay www_tls {
    listen on $ext_if port 443 tls
    protocol www_tls

    forward to <httpd> port $redirect_port 
    #check http "/" host "_healthcheck" code 200
}
