include "/etc/httpd.conf.d/macro.conf"

public_ipv4 = "<%= node[:network_setup][:v4][:address] %>"
public_ipv6 = "<%= node[:network_setup][:v6][:address] %>"


prefork 5
interval 30
log state changes
log connection # errors

# HTTP plain
http protocol http_plain {
    tcp { sack, backlog 512 }
    return error style "* { font-family: monospace; color: #f00; background-color: #333; font-weight: bold; }"
    include "/etc/relayd.conf.d/http_headers.conf"
}

relay ipv4_www {
    listen on $public_ipv4 port 80
    protocol http_plain
    forward to 127.0.0.1 port $httpd_plain_port 
}

relay ipv6_www {
    listen on $public_ipv6 port 80
    protocol http_plain
    forward to 127.0.0.1 port $httpd_plain_port 
}

<%- if !node[:relayd_tls_certs].empty? %>
# TLS
http protocol http_tls {
    tcp { sack, backlog 512 }
    tls edh params auto
    tls no tlsv1.0
    tls session tickets
    tls ciphers TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256
<%- node[:relayd_tls_certs].each do |cert| -%>
    tls { keypair <%= cert %> }
<%- end -%>

    include "/etc/relayd.conf.d/http_headers.conf"
}

relay ipv4_tls {
    listen on $public_ipv4 port 443 tls
    protocol http_tls
    forward to 127.0.0.1 port $httpd_tls_port 
}

relay ipv6_tls {
    listen on $public_ipv6 port 443 tls
    protocol http_tls
    forward to 127.0.0.1 port $httpd_tls_port 
}
<%- end %>
