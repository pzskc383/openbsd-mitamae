default_admins = { "<%= node[:prosody_admin_jid] %>" }
local _default_acl = { "pzskc383.net", "pzskc383.dp.ua", "talk.b0x.pw" }

prosody_user = "_prosody"
prosody_group = "_prosody"
pidfile = "/var/prosody/prosody.pid"
plugin_paths = { "/usr/local/lib/prosody/modules/", "/var/prosody/community-plugins" }

modules_enabled = {
		"disco";
		"roster";
		"saslauth";
		"tls";
		--
		"blocklist";
		"bookmarks";
		"carbons";
		"dialback";
		"limits";
		"pep";
		"private";
		"smacks";
		"vcard4";
		"vcard_legacy";
		--
		"account_activity";
		"cloud_notify";
		"csi_simple";
		"invites";
		"invites_adhoc";
		"invites_register";
		"ping";
		"register";
		"time";
		"uptime";
		"version";
		"mam";
		"turn_external";
		--
		"admin_adhoc";
		"admin_shell";
		"bosh";
		"websocket";
		--
		"announce";
		"groups";
		"mimicking";
		"motd";
		"s2s_bidi";
		"server_contact_info";
		"http";
		--
		"compliance_latest";
		"privilege";
}
modules_disabled = {
}

s2s_secure_auth = true
limits = {
	c2s = {
		rate = "100kb/s";
	};
	s2sin = {
		rate = "300kb/s";
	};
}

authentication = "internal_hashed"

storage = "sql"
sql = { driver = "SQLite3", database = "prosody.sqlite3" }

archive_expires_after = "1y"

turn_external_host = "turn.talk.b0x.pw"
turn_external_secret = "<%= node[:prosody_turn_secret] %>"
turn_external_tcp = true
turn_external_tls_port = 5349

log = {
	{ levels = { min = "info" }, to = "syslog" },
	{ levels = { min = "debug" }, to = "file", filename = "/var/prosody/prosody.log" },
}
statistics = "internal"
certificates = "certs"

http_ports = { 5280 }
http_interfaces = { "127.0.0.1", "::1" }
trusted_proxies = { "127.0.0.1", "::1" }
http_paths = {
    file_share = "/";
    bosh = "/http-bind"
}
c2s_direct_tls_ports = { 5223 }
s2s_direct_tls_ports = { 5270 }
https_ports = { }
https_interfaces = { }
consider_bosh_secure = true


local _slidge_transport_privileges = {
    roster = "both";
    message = "outgoing";
    iq = {
      ["http://jabber.org/protocol/pubsub"] = "both";
      ["http://jabber.org/protocol/pubsub#owner"] = "set";
      ["urn:xmpp:http:upload:0"] = "get";
    };
}

VirtualHost "talk.b0x.pw"
  name = "talk.b0x"
  unrusted_fail_watchers = { "admin@talk.b0x.pw" }
  contact_info = {
    admin = { "xmpp:admin@talk.b0x.pw" };
    abuse = { "xmpp:admin@talk.b0x.pw", "mailto:owner@post.b0x.pw" };
  }
  http_external_url = "https://talk.b0x.pw/"
  privileged_entities = {
  	  ["gram.talk.b0x.pw"] = _slidge_transport_privileges
  }

  ssl = {
    certificate = "/etc/ssl/talk_box.crt";
    key = "/etc/ssl/private/talk_box.key";
  };

  Component "chat.talk.b0x.pw" "muc"                
	name = "chat@talk.b0x"
    modules_enabled = {                             
      "muc_mam";                                  
    }         
  	restrict_room_creation = "local";
  	muc_room_default_public = true
	muc_room_default_persistent = false
	muc_room_default_members_only = false
	muc_room_default_moderated = false
	muc_room_default_public_jids = false
	muc_room_default_change_subject = true
	muc_room_default_history_length = 2000000
	muc_room_default_language = "en"
	muc_tombstones = true
	muc_tombstone_expiry = 86400 * 31
  	muc_log_by_default = true;
  	muc_log_all_rooms = true;
  	muc_log_presences = false
  	muc_log_expires_after = "1y";
  	muc_log_cleanup_interval = 4 * 60 * 60
  	muc_room_locking = true
	muc_room_lock_timeout = 180
	muc_vcard = true


  Component "share.talk.b0x.pw" "http_file_share"     
	name = "share@talk.b0x"
    modules_disabled = { "s2s" }
    http_file_share_access = { "talk.b0x.pw", "gram.talk.b0x.pw" }
    http_external_url = "https://share.talk.b0x.pw/"
    http_file_share_expires_after = "1 months"
    -- 50Mb per file, 512Mb daily, 2Gb total
    http_file_share_size_limit = 50*1024*1024
    http_file_share_daily_quota = 512*1024*1024
    http_file_share_global_quota = 5*1024*1024*1024


  Component "relay.talk.b0x.pw" "proxy65"
	name = "relay@talk.b0x"
    modules_disabled = { "s2s" }
    proxy65_address = "relay.talk.b0x.pw"
    proxy65_acl = _default_acl

  Component "gram.talk.b0x.pw"
	name = "telegram@talk.b0x.pw"
	component_secret = "<%= node[:xmpp_telegram_transport_secret] %>"
	modules_enabled = { "privilege" }



VirtualHost "pzskc383.dp.ua"
  name = "old, dead, empty"
  ssl = {
    certificate = "/etc/ssl/wild_dpua.crt";
    key = "/etc/ssl/private/wild_dpua.key";
  };
  http_external_url = "https://pzskc383.dp.ua/"


VirtualHost "pzskc383.net"
  name = "personal server"
  ssl = {
    certificate = "/etc/ssl/wild_net.crt";
    key = "/etc/ssl/private/wild_net.key";
  };
  http_external_url = "https://pzskc383.net/"


