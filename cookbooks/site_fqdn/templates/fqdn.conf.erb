<%- @fqdn_hosts.each do |type, addr| %>
# server "<%= addr %>"
server "_fqdn_<%= type %>" {
    alias "<%= addr %>"
    listen on $loopback port $httpd_plain_port
    <%- if type == "host" -%>
    alias match "*"
    listen on $loopback port $httpd_tls_port
    <%- end %>

    log {
        style forwarded
        access "access.fqdn.log"
        error "error.fqdn.log"
    }

    root "htdocs/fqdn/<%= type %>"
}
<%- end %>