# 2.3.21.1 (d492236fa0): /etc/dovecot/dovecot.conf
# Pigeonhole version 0.5.21.1 (49005e73)
# OS: OpenBSD 7.8 arm64
# Hostname: the.main.b0x.pw

listen = <%= node[:network_setup][:v4][:address] %>,<%= node[:network_setup][:v6][:address] %>
login_greeting = IMAP ready
mail_debug = yes

ssl_cert = </etc/ssl/fqdn.crt
ssl_key = </etc/ssl/private/fqdn.key

ssl_dh = </etc/ssl/dh-2048.pem
ssl_min_protocol = TLSv1.2
ssl_prefer_server_ciphers = yes

mail_gid = vmail
mail_uid = vmail
mailbox_list_index = yes

mail_plugins = "quota virtual"

first_valid_uid = 2000
last_valid_uid = 2000
first_valid_gid = 2000
last_valid_gid = 2000

managesieve_notify_capability = mailto

mmap_disable = yes
verbose_proctitle = yes

protocols = imap lmtp sieve

mail_home = /var/vmail/%d/%n/data
namespace {
  mail_location = maildir:/var/vmail/%d/%n/mail:LAYOUT=fs:INBOX=/var/vmail/%d/%n/mail/INBOX:INDEX=~/index:CONTROL=~/control
  inbox = yes
  subscriptions = yes
  separator = /
  list = yes

  mailbox Archive {
    auto = subscribe
    special_use = \Archive
  }
  mailbox Drafts {
    auto = subscribe
    special_use = \Drafts
  }
  mailbox Sent {
    auto = subscribe
    special_use = \Sent
  }
  mailbox Queue {
    auto = create
    special_use = \Sent
  }
  mailbox Spam {
    auto = create
    special_use = \Junk
  }
  mailbox Notes {
    auto = subscribe
  }
  mailbox Trash {
    auto = create
    special_use = \Trash
    # autoexpunge = 31 days
  }
}

