$ORIGIN pzskc383.net.
$TTL 15m

; zone settings
@ IN SOA f0.pzskc383.dp.ua. hostmaster ( <%= @serial %> 4h 1h 2w 1h )
@ IN NS f0.pzskc383.dp.ua.
@ IN NS a3.pzskc383.dp.ua.

; CAA/DNSSEC settings
@ IN NSEC3PARAM 1 0 0 -
@ IN CAA 128 issue "letsencrypt.org;validationmethods=dns-01"
@ IN CAA 128 issuewild "letsencrypt.org;validationmethods=dns-01"
@ IN CAA 128 iodef "mailto:reports+acme@pzskc383.net"

; apex
@ IN A <%= node[:hosts]["f0rk"].v4 %>
@ IN AAAA <%= node[:hosts]["f0rk"].v6 %>

; mail
@ IN MX 10 the.main.b0x.pw.
@ IN MX 20 the.far.b0x.pw.
@ IN TXT "v=spf1 mx -all"

; hosts
<%- node[:hosts].each do |hostname, data| -%>
<%= data.dns_shortname %> IN A <%= data.v4 %>
<%= data.dns_shortname %> IN AAAA <%= data.v6 %>
<%= data.dns_shortname %> IN TXT "v=spf1 a -all"
<%= hostname %> IN CNAME <%= data.dns_shortname %>
<% end %>

f0 IN SSHFP 4 2 60fc27ce45f77ebd4f25261f5e1b31b329fc8dc7f5d8b190ed84aad8f88c1f94
a3 IN SSHFP 4 2 f635ca62e1ec817a533094a92dcda52033ef6c7b2c9fcbc254779866c2b0dfe7

f0 IN LOC 48 12 29.4 N 16 22 25.8 E 0.0m 10.0m 1000m 10m
a3 IN LOC 51 30 26.5 N  0  7 39.9 W 0.0m 10.0m 1000m 10m

; ex1t
<%- %w[ex1t x1].each do |name| -%>
<%= name %> IN A <%= node[:ex1t].v4 %>
<%= name %> IN AAAA <%= node[:ex1t].v6 %>
<%- end -%>

; email extras
_dmarc IN TXT "v=DMARC1; p=quarantine; rua=mailto:reports+dmarc.a@pzskc383.net; ruf=mailto:reports+dmarc.f@pzskc383.net; sp=quarantine; fo=0; pct=100; adkim=s; aspf=s"
_smtp._tls IN TXT "v=TLSRPTv1; rua=mailto:reports+tls@pzskc383.net"
<%- if node[:mail_dkim_dns_rr] -%>
e._domainkey IN TXT "<%= node[:mail_dkim_dns_rr] %>"
<%- end -%>

; srv email
_submission._tcp   IN SRV 0 0 587  f0
_imap._tcp         IN SRV 0 0 143  f0
_pop3._tcp         IN SRV 0 0 0 .
_pop3s._tcp        IN SRV 0 0 0 .
_imaps._tcp        IN SRV 0 0 0 .

; srv xmpp
_xmpp-client._tcp  IN SRV 0 0 5222 f0
_xmpp-server._tcp  IN SRV 0 0 5269 f0
_xmpps-client._tcp IN SRV 0 0 5223 f0
_xmpps-server._tcp IN SRV 0 0 5270 f0

; sshfp (manual)
f0 IN SSHFP 4 2 60fc27ce45f77ebd4f25261f5e1b31b329fc8dc7f5d8b190ed84aad8f88c1f94
a3 IN SSHFP 4 2 f635ca62e1ec817a533094a92dcda52033ef6c7b2c9fcbc254779866c2b0dfe7

; maniac@pzskc383.net openpgpkey
7f8cafc8690f2707d1b7e8a40a59d8299e1af8f862576ba896acaca2._openpgpkey IN OPENPGPKEY 
