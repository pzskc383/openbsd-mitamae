$ORIGIN pzskc383.net.
$TTL 30m

@ IN SOA f0.pzskc383.dp.ua. hostmaster ( <%= @serial %> 4h 1h 2w 1h )
@ IN NS f0.pzskc383.dp.ua.
@ IN NS a3.pzskc383.dp.ua.
@ IN NSEC3PARAM 1 0 0 -
@ IN CAA 128 issue "letsencrypt.org;validationmethods=dns-01"
@ IN CAA 128 issuewild "letsencrypt.org;validationmethods=dns-01"
@ IN CAA 128 iodef "mailto:reports+acme@pzskc383.net"
@ IN A <%= node[:hosts]["f0rk"].v4 %>
@ IN AAAA <%= node[:hosts]["f0rk"].v6 %>
@ IN MX 10 f0
@ IN MX 20 a2
@ IN TXT "v=spf1 mx -all"

<%- node[:hosts].each do |hostname, data| -%>
<%= data.dns_shortname %> IN A <%= data.v4 %>
<%= data.dns_shortname %> IN AAAA <%= data.v6 %>
<%= data.dns_shortname %> IN TXT "v=spf1 a -all"
<%= hostname %> IN CNAME <%= data.dns_shortname %>
<% end %>

_dmarc IN TXT " v=DMARC1; p=quarantine; rua=mailto:reports+dmarc.a@post.pzskc383.net; ruf=mailto:reports+dmarc.f@post.pzskc383.net; sp=quarantine; fo=0; pct=100; adkim=s; aspf=s"
_smtp._tls IN TXT "v=TLSRPTv1; rua=mailto:reports+tls@post.pzskc383.net"

_submission._tcp   IN SRV 0 0 587  f0
_imap._tcp         IN SRV 0 0 143  f0
_xmpp-client._tcp  IN SRV 0 0 5222 f0
_xmpp-server._tcp  IN SRV 0 0 5269 f0
_xmpps-client._tcp IN SRV 0 0 5223 f0
_xmpps-server._tcp IN SRV 0 0 5270 f0