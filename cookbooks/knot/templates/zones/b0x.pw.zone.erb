$ORIGIN b0x.pw.
$TTL 15m

; SOA/NS
@ IN SOA a.box.ns.pzskc383.dp.ua root.post ( <%= @serial %> 4h 1h 2w 1h )
@ IN NS a.box.ns.pzskc383.dp.ua.
@ IN NS b.box.ns.pzskc383.dp.ua.

; dnssec/caa settings
@ IN NSEC3PARAM 1 0 0 -
@ IN CAA 128 issue "letsencrypt.org;validationmethods=dns-01"
@ IN CAA 128 issuewild ";"
@ IN CAA 128 iodef "mailto:reports+acme@post.b0x.pw"

; disable mail
@ IN MX 0 .
@ IN TXT "v=spf1 -all"

; apex -> f0rk
@ IN A <%= node[:hosts].f0rk.v4 %>
@ IN AAAA <%= node[:hosts].f0rk.v6 %>

; public host records

main IN A <%= node[:hosts].f0rk.v4 %>
main IN AAAA <%= node[:hosts].f0rk.v6 %>

far IN A <%= node[:hosts].airstrip3.v4 %>
far IN AAAA <%= node[:hosts].airstrip3.v6 %>

cool IN A <%= node[:hosts].v1be.v4 %>
cool IN AAAA <%= node[:hosts].v1be.v6 %>

main IN LOC 48 12 29.4 N 16 22 25.8 E 0.0m 10.0m 1000m 10m
cool IN LOC 48 12 29.4 N 16 22 25.8 E 0.0m 10.0m 1000m 10m
far  IN LOC 51 30 26.5 N  0  7 39.9 W 0.0m 10.0m 1000m 10m

; sshfp (manual)
main IN SSHFP 4 2 8fd5631b6f710dbcebe09cec091897cef0fc617fd66b94045b8864d1962ccebd
far IN SSHFP 4 2 2ba0c5cc76221ecd2c8387f7f5230ec1be335e8132beefda97fc44e0a5818fca
cool in sshfp 4 2 b286687f4c045cdbe04322a9ecfbe538af3021999dd8b9c86c3058b1821319e6

; internal hosts records
<%- node[:hosts].each do |hostname, data| -%>
s.<%= data.dns_shortname %> IN A <%= data.v4 %>
s.<%= data.dns_shortname %> IN AAAA <%= data.v6 %>
x.<%= hostname.to_s %> IN A <%= data.v4 %>
x.<%= hostname.to_s %> IN AAAA <%= data.v6 %>
<%- end %>

; post+aliases
<%- %w[post my.post mail my.mail i.was.abused.by.the].each do |host| -%>

; main records for <%= host %>
<%= host %> IN A <%= node[:hosts][:v1be][:v4] %>
<%= host %> IN AAAA <%= node[:hosts][:v1be][:v6] %>
<%= host %> IN MX 10 cool
<%= host %> IN MX 20 far

imap.<%= host %> IN A <%= node[:hosts][:v1be][:v4] %>
smtp.<%= host %> IN A <%= node[:hosts][:v1be][:v4] %>

; extra records for <%= host %>
<%= host %> IN TXT "v=spf1 mx -all"
_dmarc.<%= host %> IN TXT "v=DMARC1; p=quarantine; rua=mailto:reports+dmarc.a@post.b0x.pw; ruf=mailto:reports+dmarc.f@post.b0x.pw; sp=quarantine; fo=0; pct=100; adkim=s; aspf=s"
_smtp._tls.<%= host %> IN TXT "v=TLSRPTv1; rua=mailto:reports+tls@post.b0x.pw"
_mta-sts.<%= host %> IN TXT "v=STSv1; id=1767225600"
<%- if node[:mail_dkim_dns_rr] -%>
e._domainkey.<%= host %> IN TXT "<%= node[:mail_dkim_dns_rr] %>"
<%- end -%>

; srv records for <%= host %>
_imap._tcp.<%= host %> IN SRV 0 0 143 main
_submission._tcp.<%= host %> IN SRV 0 0 465 main

; disabled srv records for <%= host %>
_pop3._tcp.<%= host %> IN SRV 0 0 0 .
_pop3s._tcp.<%= host %> IN SRV 0 0 0 .
_imaps._tcp.<%= host %> IN SRV 0 0 0 .

<%- end -%>

; boot.my.b0x
<%- %w[boot.my xyz.boot.my].each do |host| -%>
<%= host %> IN A <%= node[:hosts][:v1be][:v4] %>
<%= host %> IN AAAA <%= node[:hosts][:v1be][:v6] %>
ipxe.<%= host %> IN A <%= node[:hosts][:v1be][:v4] %>
ipxe.<%= host %> IN AAAA <%= node[:hosts][:v1be][:v6] %>
uefi.<%= host %> IN A <%= node[:hosts][:v1be][:v4] %>
uefi.<%= host %> IN AAAA <%= node[:hosts][:v1be][:v6] %>
<%= host %> IN MX 0 .
<%- end -%>

; boot.*.on.my.b0x
<%- %w[bsd alpine fedora].each do |os| -%>
boot.<%= os %>.on.my IN A <%= node[:hosts][:v1be][:v4] %>
boot.<%= os %>.on.my IN AAAA <%= node[:hosts][:v1be][:v6] %>
boot.<%= os %>.on.my IN TXT "v=spf1 -all"
boot.<%= os %>.on.my IN MX 0 .
ipxe.boot.<%= os %>.on.my IN A <%= node[:hosts][:v1be][:v4] %>
ipxe.boot.<%= os %>.on.my IN AAAA <%= node[:hosts][:v1be][:v6] %>
ipxe.boot.<%= os %>.on.my IN TXT "v=spf1 -all"
ipxe.boot.<%= os %>.on.my IN MX 0 .
uefi.boot.<%= os %>.on.my IN A <%= node[:hosts][:v1be][:v4] %>
uefi.boot.<%= os %>.on.my IN AAAA <%= node[:hosts][:v1be][:v6] %>
uefi.boot.<%= os %>.on.my IN TXT "v=spf1 -all"
uefi.boot.<%= os %>.on.my IN MX 0 .
<%- end -%>

; talk server and components
<%- %w[talk chat.talk share.talk relay.talk gram.talk turn.talk].each do |domain| -%>
<%= domain %> IN A <%= node[:hosts][:v1be][:v4] %>
<%= domain %> IN AAAA <%= node[:hosts][:v1be][:v6] %>
<%= domain %> IN MX 0 .
<%= domain %> IN TXT "v=spf1 -all"
<%- end -%>

; main talk srv
_xmpp-client._tcp.talk  IN SRV 0 0 5222 talk
_xmpp-server._tcp.talk  IN SRV 0 0 5269 talk
_xmpps-client._tcp.talk IN SRV 0 0 5223 talk
_xmpps-server._tcp.talk IN SRV 0 0 5270 talk

; turn/stun
_stun._udp              IN SRV 0 0 3478 turn.talk
_stun._tcp              IN SRV 0 0 3478 turn.talk
_stuns._udp             IN SRV 0 0 3478 turn.talk

; subdomains for components
_xmpp-server._tcp.chat.talk    IN SRV 0 0 5269 chat.talk
_xmpps-server._tcp.chat.talk   IN SRV 0 0 5270 chat.talk
_xmpp-server._tcp.share.talk   IN SRV 0 0 5269 share.talk
_xmpps-server._tcp.share.talk  IN SRV 0 0 5270 share.talk
_xmpp-server._tcp.relay.talk   IN SRV 0 0 5269 relay.talk
_xmpps-server._tcp.relay.talk  IN SRV 0 0 5270 relay.talk
_xmpp-server._tcp.gram.talk    IN SRV 0 0 5269 gram.talk
_xmpps-server._tcp.gram.talk   IN SRV 0 0 5270 gram.talk
