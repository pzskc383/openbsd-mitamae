#!/bin/ksh

set -e

# export LEGO_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory

export LEGO_DEBUG_CLIENT_VERBOSE_ERROR=true
export LEGO_DEBUG_ACME_HTTP_CLIENT=true
export LEGO_PATH=/var/lego
export EXEC_MODE=RAW
export EXEC_PROPAGATION_TIMEOUT=90
export EXEC_SEQUENCE_INTERVAL=90
export EXEC_POLLING_INTERVAL=6

<%- if @cert[:lego_env] -%>
<%= @cert[:lego_env] %>
<%- else -%>
export RFC2136_NAMESERVER=<%= node[:hosts].f0rk.v4 %>
export RFC2136_TSIG_KEY=tsig-default
export RFC2136_TSIG_ALGORITHM=hmac-sha256
export RFC2136_TSIG_SECRET=<%= node[:knot_tsig_secret] %>
<%- end -%>

COMMAND="${1-run}"

echo "Acquiring cert: <%= @cert[:name] %>"
export LEGO_EMAIL=<%= @cert[:admin_email] %>
export CERT_NAME=<%= @cert[:name] %>
/usr/local/bin/lego \
    --accept-tos \
    <%= (@cert[:validation_method] || "--dns rfc2136") %> \
    --key-type rsa2048 \
<%- @cert[:domains].each do |domain| -%>
    --domains="<%= domain %>" \
<%- end -%>
    --pem \
    "$COMMAND" \
    --${COMMAND}-hook="${LEGO_PATH}/hook.sh"

<%- if @cert[:distributed] -%>
echo "Distributing certificates to other hosts"
timeout 10s /usr/bin/rdist -f /var/lego/distfile
<%- end -%>